# Public site URL used by sitemap, robots, canonical metadata, manifest, and share cards.
NEXT_PUBLIC_SITE_URL=https://fitmeet.app

# Optional shared webhook for all lead types.
# Can point to CRM, email automation, Notion, Feishu, Zapier, Make, or a custom backend endpoint.
FITMEET_LEADS_WEBHOOK_URL=

# Optional dedicated webhook for young-user early access demand signals.
# Falls back to FITMEET_LEADS_WEBHOOK_URL when empty.
FITMEET_WAITLIST_WEBHOOK_URL=

# Optional shared secret for signing outbound webhook requests.
# When set, FitMeet sends X-FitMeet-Timestamp and X-FitMeet-Signature headers.
FITMEET_LEADS_WEBHOOK_SECRET=

# Optional webhook timeout in milliseconds. Valid range: 1000-30000.
# Defaults to 8000 when empty or invalid.
FITMEET_LEADS_WEBHOOK_TIMEOUT_MS=8000
